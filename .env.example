# ===================================
# Viatica Backend — Environment Variables
# ===================================

# Server
NODE_ENV=development
PORT=5000

# Database (MongoDB Atlas for production)
DATABASE_FULL_URL=mongodb://127.0.0.1:27017/viatica
# Production example:
# DATABASE_FULL_URL=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/viatica?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=90d
JWT_COOKIE_EXPIRES_IN=90

# CORS — Allowed Origins (comma separated)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production example:
# ALLOWED_ORIGINS=https://viatica-dashboard.vercel.app

# Cloudinary (Image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Firebase (Push Notifications) — paste entire JSON as one line
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"..."}

# Optional
ENABLE_AUDIT=false
